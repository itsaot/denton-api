# App
PORT=5000
NODE_ENV=production
APP_BASE_URL=https://denton-api.onrender.com
FRONTEND_BASE_URL=https://dentonvisionmining.co.za
CORS_ALLOWED_ORIGINS=https://dentonvisionmining.co.za,https://www.dentonvisionmining.co.za,https://denton-api.onrender.com

# Database
MONGO_URI=mongodb://localhost:27017/denton-api

# Auth
JWT_SECRET=replace-with-your-jwt-secret

# System email (cPanel / Roundcube — same mailbox as webmail)
# Copy incoming/outgoing host from cPanel → Email Accounts → Connect Devices (must include a dot)
SYSTEM_EMAIL=System@dentonvisionmining.co.za
SYSTEM_EMAIL_PASSWORD=your-mailbox-password
SMTP_HOST=mail.dentonvisionmining.co.za
SMTP_PORT=465
MAIL_FROM_NAME=Denton Vision Mining
ADMIN_EMAILS=System@dentonvisionmining.co.za

# Existing Stripe payment flow
STRIPE_SECRET_KEY=sk_test_replace_me

# GitHub-backed uploads
GITHUB_TOKEN=replace-with-your-github-token
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main

# Ozow payment flow
OZOW_SITE_CODE=replace-with-your-ozow-site-code
OZOW_SECRET_KEY=replace-with-your-ozow-secret-key
OZOW_API_KEY=replace-with-your-ozow-api-key
OZOW_IS_TEST=true
OZOW_BASE_URL=https://pay.ozow.com
OZOW_API_BASE_URL=https://api.ozow.com
OZOW_COUNTRY_CODE=ZA
OZOW_CURRENCY_CODE=ZAR
OZOW_SUCCESS_URL=http://localhost:5000/api/payments/ozow/callback/success
OZOW_CANCEL_URL=http://localhost:5000/api/payments/ozow/callback/cancel
OZOW_ERROR_URL=http://localhost:5000/api/payments/ozow/callback/error
OZOW_NOTIFY_URL=http://localhost:5000/api/payments/ozow/callback/notify
